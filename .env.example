# SaasPwn - API Keys Configuration
# Copy file ini ke .env dan isi dengan API key kamu:
#   cp .env.example .env

# Shodan (https://account.shodan.io/)
SHODAN_API_KEY=

# Censys (https://search.censys.io/account/api)
CENSYS_API_ID=
CENSYS_API_SECRET=

# GitHub Token (optional, untuk TruffleHog scan private repos)
# https://github.com/settings/tokens
GITHUB_TOKEN=
